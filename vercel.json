{
  "version": 2,
  "builds": [
    {
      "src": "comptaauto/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 25
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "comptaauto/wsgi.py"
    }
  ],
  "functions": {
    "comptaauto/wsgi.py": {
      "includeFiles": "staticfiles/**"
    }
  }
}
